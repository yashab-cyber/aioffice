# ─── LLM Provider ──────────────────────────
# Set which provider to use: openai | anthropic | gemini | ollama | groq | openrouter | mistral | together | deepseek | custom
LLM_PROVIDER=openai

# ─── OpenAI ────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=              # optional: custom endpoint

# ─── Anthropic ─────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Google Gemini ─────────────────────────
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash

# ─── Ollama (Local) ────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3

# ─── Groq ──────────────────────────────────
# GROQ_API_KEY=gsk_your-groq-key
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenRouter ────────────────────────────
# OPENROUTER_API_KEY=sk-or-your-key
# OPENROUTER_MODEL=openai/gpt-4o

# ─── Mistral AI ────────────────────────────
# MISTRAL_API_KEY=your-mistral-key
# MISTRAL_MODEL=mistral-large-latest

# ─── Together AI ───────────────────────────
# TOGETHER_API_KEY=your-together-key
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ─── DeepSeek ──────────────────────────────
# DEEPSEEK_API_KEY=your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat

# ─── Custom / Local (OpenAI-compatible) ────
# Works with: LM Studio, text-generation-webui, LocalAI, vLLM, Kobold, etc.
# Set LLM_PROVIDER=custom and configure below:
# CUSTOM_BASE_URL=http://localhost:4141/v1
# CUSTOM_MODEL=my-local-model
# CUSTOM_API_KEY=                # optional: some servers require a key

# ─── Telegram Bot ──────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ─── Email (SMTP) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# ─── Product Info ──────────────────────────
PRODUCT_GITHUB_URL=https://github.com/yashab-cyber/hackbot
PRODUCT_DISCORD_URL=https://discord.gg/X2tgYHXYq
PRODUCT_NAME=HackBot
COMPANY_NAME=HackBot Inc.

# ─── Server ────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Persistence ───────────────────────────
DATABASE_PATH=data/aioffice.db
STATE_DIR=data/state
MEMORY_DIR=data/memory
LOG_DIR=logs

# ─── Schedule ──────────────────────────────
WORK_START_HOUR=9
WORK_END_HOUR=18
REPORT_HOUR=18
TIMEZONE=UTC
